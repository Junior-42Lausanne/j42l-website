# Dockerfile
FROM node:20-bookworm-slim

WORKDIR /opt/app
ENV NODE_ENV=production

# Build tools just in case native modules are needed
RUN apt-get update && apt-get install -y python3 make g++ && rm -rf /var/lib/apt/lists/*

COPY package*.json ./

# Important: install optional deps so sharp is included
RUN npm ci --include=optional

COPY . .
RUN npm run build

EXPOSE 1337
CMD ["npm","run","start"]
